{
  "name": "mediafox",
  "version": "0.1.0",
  "description": "Social media management for the Fox Suite",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "client:dev": "npm run dev --prefix client",
    "build:server": "tsc",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "test": "npm run build:server && node --test dist/tests/**/*.test.js"
  },
  "dependencies": {
    "@atproto/api": "^0.13.30",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.9.0",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "nanoid": "3.3.7",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.9",
    "sharp": "^0.34.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
