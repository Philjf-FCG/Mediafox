PORT=5004
NODE_ENV=development
DATABASE_PATH=/opt/data/mediafox.db
MEDIA_STORAGE_PATH=/opt/data/media

# FoxAuth integration
FOXAUTH_JWT_SECRET=change-me-in-production

# Token encryption (32+ byte hex string)
TOKEN_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string-in-production

# Meta / Facebook / Instagram
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:5004/api/accounts/connect/meta/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5004/api/accounts/connect/linkedin/callback

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5004/api/accounts/connect/slack/callback

# Discord bot (for inbox features)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5004/api/accounts/connect/discord/callback

# AI features (optional)
ANTHROPIC_API_KEY=

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=mediafox@yourdomain.com

AUTH_DEV_BYPASS=true
